# Hızlısanayi Root Environment Variables Configuration
# Copy this file to .env at the root of the project for local developments (if needed),
# and copy respective vars to frontend/.env and backend/.env as shown below.

# -----------------------------------------------------------------------------
# 1. Frontend Environment Variables (frontend/.env)
# -----------------------------------------------------------------------------
# Supabase URL and Anon Key
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (for local development, use your machine's LAN IP. e.g. http://192.168.1.100:8000)
EXPO_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# 2. Backend Environment Variables (backend/.env)
# -----------------------------------------------------------------------------
# Supabase project details (service role needed for administrative actions)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_WEBHOOK_SECRET=your-supabase-webhook-secret-configured-in-db

# Push Notifications Configuration
EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send

# AI Refinement API
GEMINI_API_KEY=your-gemini-api-key
